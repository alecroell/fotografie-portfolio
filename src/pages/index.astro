---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Alec Roell Fotografie">
  <main class="page">
    <header class="intro" aria-labelledby="home-title">
      <h1 id="home-title">Wat leuk dat je hier bent!</h1>
      <p>
        Ik ben Alec en fotografeer producten, evenementen, plekken en portretten.
        Neem gerust een kijkje.
      </p>
    </header>

    <section class="tiles" aria-label="Snelle navigatie">
      <article class="tile">
        <a class="tileLink" href="/portfolio" aria-label="Bekijk portfolio">
          <figure class="frame">
            <img
              src="/fotos/45.jpg"
              alt="Portfolio sfeerbeeld"
              loading="eager"
              decoding="async"
            />
          </figure>
          <span class="cta">Bekijk portfolio</span>
        </a>
      </article>

      <article class="tile">
        <a class="tileLink" href="/contact" aria-label="Ga naar contact">
          <figure class="frame">
            <img
              src="/fotos/1000002990.jpg"
              alt="Contact sfeerbeeld"
              loading="lazy"
              decoding="async"
            />
          </figure>
          <span class="cta">Contact</span>
        </a>
      </article>
    </section>
  </main>

  <style>
    :global(:root) {
      --ink: #111;
      --muted: #4b4b4b;
      --line: rgba(0, 0, 0, 0.14);
      --paper: #fff;
      --max: 1100px;
      --accent: #6b3d2e; /* bruin */
    }

    .page {
      max-width: var(--max);
      margin: 0 auto;
      padding: 3.5rem 1.5rem 5rem;
      color: var(--ink);
      background: var(--paper);
    }

    .intro {
      text-align: center;
      margin-bottom: 2.75rem;
    }

    .intro h1 {
      font-family: ui-serif, "Iowan Old Style", "Palatino Linotype", Palatino,
        Garamond, Georgia, serif;
      font-weight: 600;
      letter-spacing: 0.2px;
      font-size: clamp(2.05rem, 3vw, 3rem);
      line-height: 1.15;
      margin: 0 0 0.75rem;
      color: var(--accent);
    }

    .intro p {
      max-width: 62ch;
      margin: 0 auto;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto,
        Arial, "Noto Sans", "Liberation Sans", sans-serif;
      font-size: 1.05rem;
      line-height: 1.7;
      color: var(--muted);
    }

    .tiles {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 3.25rem;
      align-items: start;
      justify-items: center;
    }

    .tile {
      width: 100%;
      display: grid;
      justify-items: center;
    }

    .tileLink {
      width: 100%;
      max-width: 440px;
      text-decoration: none;
      color: inherit;
      display: grid;
      gap: 1.25rem;
      justify-items: center;
    }

    .frame {
      width: 100%;
      margin: 0;
      border: 1px solid var(--line);
      background: #fafafa;
      overflow: hidden;
    }

    .frame img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      display: block;
      border-radius: 0;
      transform: scale(1);
      transition: transform 220ms ease;
    }

    .tileLink:hover .frame img {
      transform: scale(1.02);
    }

    .cta {
      display: inline-block;
      padding: 0.85rem 1.6rem;
      border: 1px solid var(--line);
      background: transparent;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-weight: 600;
      font-size: 0.82rem;
      font-family: ui-serif, "Iowan Old Style", "Palatino Linotype", Palatino,
        Garamond, Georgia, serif;
      color: var(--accent);
      transition: background 180ms ease, border-color 180ms ease;
    }

    .tileLink:hover .cta {
      background: rgba(107, 61, 46, 0.04);
      border-color: rgba(107, 61, 46, 0.35);
    }

    @media (max-width: 920px) {
      .tiles {
        grid-template-columns: 1fr;
        gap: 2.25rem;
      }
      .tileLink {
        max-width: 520px;
      }
    }
  </style>
</Layout>