---
import Layout from "../../../layouts/Layout.astro";

const categoryTitle = "Portret & Evenement";
const albums = [
  {
    title: "Francine",
    href: "/portfolio/portret-evenement/francine",
    cover: "/fotos/portfolio/portret-evenement/francine/Francine.jpeg",
  },
];
---

<Layout>
  <main class="page">
    <header class="intro">
      <h1>{categoryTitle}</h1>
      <p>Kies een album om de foto’s te bekijken.</p>
    </header>

    <section class="grid" aria-label="Albums">
      {albums.map((a) => (
        <article class="card">
          <a class="cardLink" href={a.href} aria-label={`Bekijk album ${a.title}`}>
            <figure class="frame">
              <img src={a.cover} alt={`${a.title} cover`} loading="eager" decoding="async" />
            </figure>
            <h2 class="name">{a.title}</h2>
            <span class="btn">Bekijk album</span>
          </a>
        </article>
      ))}
    </section>
  </main>

  <style>
    .page {
      max-width: 1100px;
      margin: 0 auto;
      padding: 4.5rem 1.5rem 5.5rem;
    }

    .intro {
      text-align: center;
      margin-bottom: 2.25rem;
    }

    .intro h1 {
      font-family: ui-serif, "Iowan Old Style", "Palatino Linotype", Palatino,
        Garamond, Georgia, serif;
      font-weight: 600;
      letter-spacing: 0.2px;
      font-size: clamp(2.05rem, 3vw, 3rem);
      line-height: 1.15;
      margin: 0 0 0.65rem;
      color: var(--accent);
    }

    .intro p {
      margin: 0 auto;
      max-width: 62ch;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto,
        Arial, sans-serif;
      color: rgba(17, 17, 17, 0.72);
      line-height: 1.7;
    }

    /* ===== Grid zoals Reizen & Plekken ===== */
    .grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 3.25rem;
      align-items: start;
      justify-items: center;
    }

    .card {
      width: 100%;
      max-width: 340px;
      display: grid;
      justify-items: center;
      text-align: center;
    }

    .cardLink {
      width: 100%;
      text-decoration: none;
      color: inherit;
      display: grid;
      justify-items: center;
      gap: 1rem;
    }

    .frame {
      width: 100%;
      margin: 0;
      border: 1px solid rgba(0, 0, 0, 0.14);
      background: #fafafa;
    }

    .frame img {
      width: 100%;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      display: block;
      transform: scale(1);
      transition: transform 220ms ease;
    }

    .cardLink:hover .frame img {
      transform: scale(1.02);
    }

    .name {
      margin: 0.35rem 0 0;
      font-family: ui-serif, "Iowan Old Style", "Palatino Linotype", Palatino,
        Garamond, Georgia, serif;
      font-weight: 600;
      font-size: 1.1rem;
      color: rgba(17, 17, 17, 0.9);
    }

    .btn {
      display: inline-block;
      padding: 0.75rem 1.35rem;
      border: 1px solid rgba(0, 0, 0, 0.14);
      text-transform: uppercase;
      letter-spacing: 2px;
      font-weight: 600;
      font-size: 0.78rem;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto,
        Arial, sans-serif;
      color: var(--accent);
      transition: background 180ms ease, border-color 180ms ease;
    }

    .cardLink:hover .btn {
      background: rgba(0, 0, 0, 0.03);
      border-color: rgba(0, 0, 0, 0.22);
    }

    @media (max-width: 920px) {
      .grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 2.5rem;
      }
      .card {
        max-width: 420px;
      }
    }

    @media (max-width: 640px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>