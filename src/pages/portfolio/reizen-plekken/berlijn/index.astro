---
import Layout from "../../../../layouts/Layout.astro";
import LightboxGallery from "../../../../components/LightboxGallery.astro";
---

<Layout title="Berlijn — Reizen & Plekken">
  <main>
    <header class="intro">
      <h1>Berlijn</h1>
      <p>Klik op een foto om te vergroten.</p>
    </header>

    <LightboxGallery
      images={[
        { src: "/fotos/portfolio/reizen-plekken/berlijn/df.jpg", alt: "Berlijn" },
        { src: "/fotos/portfolio/reizen-plekken/berlijn/fv.jpg", alt: "Berlijn" },
        { src: "/fotos/portfolio/reizen-plekken/berlijn/g.jpg", alt: "Berlijn" },
        { src: "/fotos/portfolio/reizen-plekken/berlijn/hjhj.jpg", alt: "Berlijn" },
        { src: "/fotos/portfolio/reizen-plekken/berlijn/ubahn.jpg", alt: "Berlijn" },
      ]}
      columns={3}
      fit="cover"
      overlayBg="rgba(0,0,0,0.6)"
    />
  </main>

  <style>
    .intro { text-align:center; margin: 0 0 2rem; }
    .intro h1 { color: var(--accent); margin: 0 0 .5rem; }
    .intro p { margin: 0; opacity: .75; }
  </style>
</Layout>