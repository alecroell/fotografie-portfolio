---
import Layout from "../../../layouts/Layout.astro";
---

<Layout>
  <main class="page">
    <header class="intro">
      <h1>Portfolio</h1>
      <p>Kies een categorie om albums te bekijken.</p>
    </header>

    <section class="categories">

      <!-- Reizen & Plekken -->
      <article class="card">
        <a href="/portfolio/reizen-plekken">
          <img 
            src="/fotos/portfolio/reizen-plekken/berlijn/ubahn.jpg" 
            alt="Reizen & Plekken"
          />
          <h2>Reizen & Plekken</h2>
          <span class="button">Bekijk Albums</span>
        </a>
      </article>

      <!-- Portret & Evenement -->
      <article class="card">
        <a href="/portfolio/portret-evenement">
          <img 
            src="/fotos/portfolio/portret-evenement/francine/Francine.jpeg" 
            alt="Portret & Evenement"
          />
          <h2>Portret & Evenement</h2>
          <span class="button">Bekijk Albums</span>
        </a>
      </article>

      <!-- Product & Interieur -->
      <article class="card">
        <a href="/portfolio/product-interieur">
          <img 
            src="/fotos/portfolio/product-interieur/wienshout/lw hout stoel2.jpg" 
            alt="Product & Interieur"
          />
          <h2>Product & Interieur</h2>
          <span class="button">Bekijk Albums</span>
        </a>
      </article>

    </section>
  </main>

  <style>
    .page {
      text-align: center;
    }

    .intro {
      margin-bottom: 3rem;
    }

    .intro h1 {
      color: var(--accent);
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
    }

    .categories {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }

    .card a {
      text-decoration: none;
      color: inherit;
    }

    .card img {
      width: 100%;
      height: 420px;
      object-fit: cover;
      border: 1px solid rgba(0,0,0,0.15);
      transition: transform 0.3s ease;
    }

    .card img:hover {
      transform: scale(1.02);
    }

    .card h2 {
      margin: 1.2rem 0 0.5rem;
      color: var(--accent);
      font-weight: 600;
    }

    .button {
      display: inline-block;
      padding: 0.6rem 1.4rem;
      border: 1px solid rgba(0,0,0,0.2);
      font-size: 0.8rem;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    @media (max-width: 900px) {
      .categories {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>