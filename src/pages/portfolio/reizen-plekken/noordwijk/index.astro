---
import Layout from "../../../../layouts/Layout.astro";
import LightboxGallery from "../../../../components/LightboxGallery.astro";
---

<Layout title="Noordwijk — Reizen & Plekken">
  <main>
    <header class="intro">
      <h1>Noordwijk</h1>
      <p>Klik op een foto om te vergroten.</p>
    </header>

    <LightboxGallery
      images={[
        { src: "/fotos/portfolio/reizen-plekken/noordwijk/vogel_2.jpg", alt: "Noordwijk" },
        { src: "/fotos/portfolio/reizen-plekken/noordwijk/vogel_3.jpg", alt: "Noordwijk" },
        { src: "/fotos/portfolio/reizen-plekken/noordwijk/vogel_10.jpg", alt: "Noordwijk" },
        { src: "/fotos/portfolio/reizen-plekken/noordwijk/vogel_6.jpg", alt: "Noordwijk" },
      ]}
      columns={3}
      fit="cover"
      overlayBg="rgba(0,0,0,0.6)"
    />
  </main>

  <style>
    .intro { text-align:center; margin: 0 0 2rem; }
    .intro h1 { color: var(--accent); margin: 0 0 .5rem; }
    .intro p { margin: 0; opacity: .75; }
  </style>
</Layout>