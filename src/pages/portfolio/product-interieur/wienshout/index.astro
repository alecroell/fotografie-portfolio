---
import Layout from "../../../../layouts/Layout.astro";
import LightboxGallery from "../../../../components/LightboxGallery.astro";
---

<Layout title="Wienshout — Product & Interieur">
  <main>
    <header class="intro">
      <h1>Wienshout</h1>
      <p>Klik op een foto om te vergroten.</p>
    </header>

    <LightboxGallery
      images={[
        { src: "/fotos/portfolio/product-interieur/wienshout/gegegf.jpg", alt: "Wienshout" },
        { src: "/fotos/portfolio/product-interieur/wienshout/gg.jpg", alt: "Wienshout" },
        { src: "/fotos/portfolio/product-interieur/wienshout/kampie%20wood%202.jpg", alt: "Wienshout" },
        { src: "/fotos/portfolio/product-interieur/wienshout/kampie%20wood.jpg", alt: "Wienshout" },
        { src: "/fotos/portfolio/product-interieur/wienshout/lw%20hout%20stoel2.jpg", alt: "Wienshout" },
        { src: "/fotos/portfolio/product-interieur/wienshout/wood%20ezel.jpg", alt: "Wienshout" },
        { src: "/fotos/portfolio/product-interieur/wienshout/peukie_2.jpg", alt: "Wienshout" },
        { src: "/fotos/portfolio/product-interieur/wienshout/peukie_3h.jpg", alt: "Wienshout" },
        { src: "/fotos/portfolio/product-interieur/wienshout/peukie_4.jpg", alt: "Wienshout" },
        { src: "/fotos/portfolio/product-interieur/wienshout/peukie_5.jpg", alt: "Wienshout" },
        { src: "/fotos/portfolio/product-interieur/wienshout/peukie_6.jpg", alt: "Wienshout" },
        { src: "/fotos/portfolio/product-interieur/wienshout/peukie_7.jpg", alt: "Wienshout" },
      ]}
      columns={3}
      fit="cover"
      overlayBg="rgba(0,0,0,0.6)"
    />
  </main>

  <style>
    .intro { text-align:center; margin: 0 0 2rem; }
    .intro h1 { color: var(--accent); margin: 0 0 .5rem; }
    .intro p { margin: 0; opacity: .75; }
  </style>
</Layout>