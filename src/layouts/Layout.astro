---
const { title = "ALECROELLFOTOGRAFIE" } = Astro.props;
const path = Astro.url.pathname;

const isActive = (href: string): boolean => {
  if (href === "/") return path === "/";
  return path.toLowerCase().startsWith(href.toLowerCase());
};
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <!-- Favicon setup -->
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#6b3d2e" />
  </head>

  <body>
    <div class="wrap">
      <header class="siteHeader">
        <a class="brand" href="/">ALECROELLFOTOGRAFIE</a>

        <nav class="nav" aria-label="Hoofdnavigatie">
          <a class={isActive("/portfolio") ? "active" : ""} href="/portfolio">
            PORTFOLIO
          </a>
          <a class={isActive("/contact") ? "active" : ""} href="/contact">
            CONTACT
          </a>
          <a class={isActive("/") ? "active" : ""} href="/">
            HOME
          </a>
        </nav>
      </header>

      <main class="content">
        <slot />
      </main>
    </div>

    <style>
      :global(:root) {
        --accent: #6b3d2e;
        --max: 1180px;
      }

      :global(body) {
        margin: 0;
        background: #fff;
        color: #111;
      }

      /* Page container */
      .wrap {
        max-width: var(--max);
        margin: 0 auto;
        padding: 3rem 2.5rem 5rem;
      }

      /* Header layout */
      .siteHeader {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 2rem;
      }

      /* Brand */
      .brand {
        font-family: ui-serif, "Iowan Old Style", "Palatino Linotype", Palatino,
          Garamond, Georgia, serif;
        font-weight: 600;
        letter-spacing: 3.4px;
        text-transform: uppercase;
        font-size: 1.3rem;
        color: var(--accent);
        text-decoration: none;
        white-space: nowrap;
      }

      /* Navigation */
      .nav {
        display: flex;
        gap: 3.5rem;
        align-items: baseline;
      }

      .nav a {
        font-family: ui-serif, "Iowan Old Style", "Palatino Linotype", Palatino,
          Garamond, Georgia, serif;
        text-transform: uppercase;
        letter-spacing: 3.2px;
        font-size: 0.95rem;
        color: var(--accent);
        text-decoration: none;
        padding-bottom: 0.3rem;
        border-bottom: 1px solid transparent;
        opacity: 0.95;
        transition: opacity 160ms ease, border-color 160ms ease;
      }

      .nav a:hover {
        opacity: 1;
        border-bottom-color: rgba(107, 61, 46, 0.35);
      }

      .nav a.active {
        opacity: 1;
        border-bottom-color: rgba(107, 61, 46, 0.6);
      }

      .content {
        padding-top: 6rem;
      }

      @media (max-width: 860px) {
        .wrap {
          padding: 2rem 1.5rem 4rem;
        }

        .content {
          padding-top: 3rem;
        }

        .nav {
          gap: 2rem;
        }
      }

      @media (max-width: 640px) {
        .siteHeader {
          flex-direction: column;
          align-items: flex-start;
          gap: 1rem;
        }

        .nav {
          gap: 1.5rem;
        }
      }
    </style>
  </body>
</html>